# ============================================================================
# Local development environment variables
#
# 1. Copy this file to `.env.local` (which is gitignored — never committed).
# 2. Fill in the values from your DEV Supabase project.
# 3. Restart `npm run dev` after editing.
#
# DO NOT commit `.env.local`. DO NOT share it.
# For production (Netlify), set these in the Netlify UI instead — see
# docs/DEPLOYMENT.md.
# ============================================================================

# Supabase Project URL — Settings → Data API → Project URL
# Just the hostname, NO path (no `/rest/v1`, no trailing slash).
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Publishable (or anon) key — safe to expose to the browser.
# Settings → API → "Publishable key" (or the legacy "anon" key).
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxx

# Secret key — KEEP SECRET. Used only on the server. Bypasses RLS.
# Settings → API → "Secret key" (or the legacy "service_role" key).
SUPABASE_SECRET_KEY=sb_secret_xxxxxxxxxxxx

# Public app URL — used for auth redirect URLs in invite/recovery emails.
# Local development: http://localhost:3000
# Production: your real URL, e.g. https://welfare.yourcompany.lk
NEXT_PUBLIC_APP_URL=http://localhost:3000
